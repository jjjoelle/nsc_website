---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const students = await getCollection("students");
const studentMap = Object.fromEntries(students.map((s) => [s.id, s.data.name]));

// Get unique values for filters
const types = [...new Set(projects.map((p) => p.data.type))].sort();
const tags = [...new Set(projects.flatMap((p) => p.data.tags ?? []))].sort();
---

<BaseLayout title="Projects">
  <section class="mb-8">
    <h2 class="text-5xl font-black tracking-tight mb-2">Projects</h2>
    <div class="w-16 h-1 bg-eth-red mb-4"></div>
    <p class="text-ink-light max-w-2xl">
      Thesis and short projects completed by NSC students.
    </p>
  </section>

  <div class="mb-8 flex flex-wrap gap-6 items-end">
    <div>
      <label class="text-xs font-semibold uppercase tracking-wider text-ink-light block mb-2">Type</label>
      <div class="flex gap-2" id="type-filters">
        <button class="type-btn filter-active text-xs font-semibold uppercase tracking-wider px-3 py-1.5 border-2 border-border-bold bg-ink text-white" data-type="all">All</button>
        {types.map((type) => (
          <button class="type-btn text-xs font-semibold uppercase tracking-wider px-3 py-1.5 border-2 border-border hover:border-border-bold transition-colors" data-type={type}>
            {type === "thesis" ? "Thesis" : type === "short" ? "Short" : "Other"}
          </button>
        ))}
      </div>
    </div>
    <div>
      <label class="text-xs font-semibold uppercase tracking-wider text-ink-light block mb-2">Location</label>
      <div class="flex gap-2" id="ini-toggle">
        <button class="ini-btn text-xs font-semibold uppercase tracking-wider px-3 py-1.5 border-2 border-border-bold bg-ink text-white" data-ini="all">All</button>
        <button class="ini-btn text-xs font-semibold uppercase tracking-wider px-3 py-1.5 border-2 border-border hover:border-border-bold transition-colors" data-ini="true">At INI</button>
        <button class="ini-btn text-xs font-semibold uppercase tracking-wider px-3 py-1.5 border-2 border-border hover:border-border-bold transition-colors" data-ini="false">External</button>
      </div>
    </div>
  </div>

  <div class="mb-6">
    <input
      type="text"
      id="search-input"
      placeholder="Search projects..."
      class="w-full max-w-md px-4 py-2 border-2 border-border focus:border-border-bold focus:outline-none text-sm"
    />
  </div>

  {tags.length > 0 && (
    <div class="mb-8">
      <label class="text-xs font-semibold uppercase tracking-wider text-ink-light block mb-2">Keywords</label>
      <div class="flex gap-2 flex-wrap" id="tag-filters">
        {tags.map((tag) => (
          <button
            class="tag-btn text-xs font-mono px-3 py-1.5 border-2 border-border hover:border-border-bold transition-colors"
            data-tag={tag}
          >
            #{tag}
          </button>
        ))}
      </div>
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" id="project-grid">
    {projects
      .sort((a, b) => b.data.year - a.data.year)
      .map((project) => (
        <div
          data-type={project.data.type}
          data-ini={project.data.at_ini === true ? "true" : project.data.at_ini === false ? "false" : ""}
          data-tags={JSON.stringify(project.data.tags ?? [])}
          data-search={`${project.data.title} ${project.data.abstract} ${project.data.lab} ${project.data.supervisors.join(" ")} ${studentMap[project.data.student] || project.data.student}`.toLowerCase()}
        >
          <ProjectCard
            slug={project.id}
            title={project.data.title}
            type={project.data.type}
            student={project.data.student}
            studentName={studentMap[project.data.student]}
            abstract={project.data.abstract}
            lab={project.data.lab}
            year={project.data.year}
            supervisors={project.data.supervisors}
            tags={project.data.tags}
          />
        </div>
      ))}
  </div>
</BaseLayout>

<script>
  let activeType = "all";
  let activeIni = "all";
  let searchQuery = "";
  const activeTags = new Set<string>();

  const cards = document.querySelectorAll<HTMLElement>("#project-grid > div");
  const typeButtons = document.querySelectorAll<HTMLButtonElement>(".type-btn");
  const iniButtons = document.querySelectorAll<HTMLButtonElement>(".ini-btn");
  const tagButtons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const searchInput = document.querySelector<HTMLInputElement>("#search-input")!;

  function applyFilters() {
    cards.forEach((card) => {
      const matchType = activeType === "all" || card.dataset.type === activeType;
      const matchIni = activeIni === "all" || card.dataset.ini === activeIni;
      const cardTags: string[] = JSON.parse(card.dataset.tags || "[]");
      const matchTag = activeTags.size === 0 || [...activeTags].every((t) => cardTags.includes(t));
      const matchSearch = !searchQuery || (card.dataset.search?.includes(searchQuery) ?? true);
      card.style.display = matchType && matchIni && matchTag && matchSearch ? "" : "none";
    });
  }

  function activateButton(buttons: NodeListOf<HTMLButtonElement>, active: HTMLButtonElement) {
    buttons.forEach((b) => {
      b.classList.remove("bg-ink", "text-white", "border-border-bold");
      b.classList.add("border-border");
    });
    active.classList.add("bg-ink", "text-white", "border-border-bold");
    active.classList.remove("border-border");
  }

  typeButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeType = btn.dataset.type || "all";
      activateButton(typeButtons, btn);
      applyFilters();
    });
  });

  iniButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeIni = btn.dataset.ini || "all";
      iniButtons.forEach((b) => {
        b.classList.remove("bg-ink", "text-white", "border-border-bold");
        b.classList.add("border-border");
      });
      btn.classList.add("bg-ink", "text-white", "border-border-bold");
      btn.classList.remove("border-border");
      applyFilters();
    });
  });

  searchInput.addEventListener("input", () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    applyFilters();
  });

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.dataset.tag!;
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.classList.remove("bg-ink", "text-white", "border-border-bold");
        btn.classList.add("border-border");
      } else {
        activeTags.add(tag);
        btn.classList.add("bg-ink", "text-white", "border-border-bold");
        btn.classList.remove("border-border");
      }
      applyFilters();
    });
  });
</script>

---
import BaseLayout from "../layouts/BaseLayout.astro";

const sections = [
  {
    href: "/students",
    label: "Students",
    description: "Meet current and alumni NSC students.",
  },
  {
    href: "/projects",
    label: "Projects",
    description: "Browse thesis projects, short projects, and more.",
  },
  {
    href: "/blog",
    label: "Blog",
    description: "Read posts written by students about their work.",
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="mt-4 mb-12 flex flex-col sm:flex-row sm:items-start gap-8">
    <div class="flex-1">
      <div class="w-24 h-1.5 bg-eth-red mb-6"></div>
      <p class="text-lg text-ink-light max-w-2xl leading-relaxed mb-4">
        Welcome to the Virtual Masters Room! :)
      </p>
      <p class="text-lg text-ink-light max-w-2xl leading-relaxed">
        A virtual hub for students of the
        Neural Systems &amp; Computation (NSC) MSc program,
        a joint degree between ETH Zurich and the University of Zurich, hosted at the
        Institute of Neuroinformatics (INI).
        Here you'll find thesis projects, short projects, and blog posts from
        current students and alumni.
      </p>
    </div>
    <div class="shrink-0 flex justify-center sm:justify-end">
      <img src="/ini_man.gif" alt="INI mascot" class="h-56 w-auto" />
    </div>
  </section>

  <!-- Section cards -->
  <section class="mb-8">
    <h3 class="text-2xl font-black tracking-tight mb-4">Explore</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {sections.map((s) => (
        <a
          href={s.href}
          class="group border-2 border-border hover:border-border-bold transition-colors p-6 flex flex-col justify-between"
        >
          <div>
            <span class="text-xl font-black tracking-tight">{s.label}</span>
            <p class="text-sm text-ink-light mt-1">{s.description}</p>
          </div>
          <span class="mt-4 text-eth-red font-bold text-sm uppercase tracking-wider group-hover:translate-x-1 transition-transform inline-block">
            View &rarr;
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>


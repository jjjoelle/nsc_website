---
interface Props {
  title: string;
  type: string;
  student: string;
  studentName?: string;
  abstract: string;
  lab: string;
  year: number;
  supervisors: string[];
  pdf_url?: string;
  code_url?: string;
  slides_url?: string;
}

const { title, type, student, studentName, abstract, lab, year, supervisors, pdf_url, code_url, slides_url } = Astro.props;
const typeLabel = type === "thesis" ? "Thesis" : type === "short" ? "Short Project" : "Other";
const typeColor = type === "thesis" ? "bg-eth-red text-white" : "bg-ink text-white";
---

<div class="border-2 border-border p-6">
  <div class="flex items-start gap-3 mb-3">
    <span class={`text-xs font-bold uppercase tracking-wider px-2 py-1 ${typeColor}`}>{typeLabel}</span>
    <span class="text-xs font-mono text-ink-light ml-auto">{year}</span>
  </div>
  <h3 class="text-lg font-bold leading-snug mb-2">{title}</h3>
  <p class="text-sm text-ink-light mb-3 line-clamp-3">{abstract}</p>
  <div class="text-xs text-ink-light space-y-1 mb-4">
    <p>
      <span class="font-semibold">Student:</span>{" "}
      <a href={`/students/${student}`} class="text-eth-red hover:underline">{studentName || student}</a>
    </p>
    <p><span class="font-semibold">Lab:</span> {lab}</p>
    <p><span class="font-semibold">Supervisors:</span> {supervisors.join(", ")}</p>
  </div>
  <div class="flex gap-4 text-xs font-semibold uppercase tracking-wider">
    {pdf_url && <a href={pdf_url} class="text-eth-red hover:underline">PDF</a>}
    {code_url && <a href={code_url} class="text-eth-red hover:underline">Code</a>}
    {slides_url && <a href={slides_url} class="text-eth-red hover:underline">Slides</a>}
  </div>
</div>

---
interface Props {
  slug: string;
  title: string;
  type: string;
  student: string;
  studentName?: string;
  abstract: string;
  lab: string;
  year: number;
  supervisors: string[];
  tags?: string[];
}

const { slug, title, type, student, studentName, abstract, lab, year, supervisors, tags } = Astro.props;
const typeLabel = type === "thesis" ? "Thesis" : type === "short" ? "Short Project" : "Other";
const typeColor = type === "thesis" ? "bg-eth-red text-white" : "bg-ink text-white";
---

<a href={`/projects/${slug}`} class="block border-2 border-border hover:border-border-bold transition-colors p-6 group">
  <div class="flex items-start gap-3 mb-3">
    <span class={`text-xs font-bold uppercase tracking-wider px-2 py-1 ${typeColor}`}>{typeLabel}</span>
    <span class="text-xs font-mono text-ink-light ml-auto">{year}</span>
  </div>
  <h3 class="text-lg font-bold leading-snug mb-2 group-hover:text-eth-red transition-colors">{title}</h3>
  <p class="text-sm text-ink-light mb-3 line-clamp-3">{abstract}</p>
  <div class="text-xs text-ink-light space-y-1 mb-4">
    <p><span class="font-semibold">Student:</span> {studentName || student}</p>
    <p><span class="font-semibold">Lab:</span> {lab}</p>
    <p><span class="font-semibold">Supervisors:</span> {supervisors.join(", ")}</p>
  </div>
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tags.map((tag) => (
        <span class="text-xs font-mono text-ink-light">#{tag}</span>
      ))}
    </div>
  )}
  <span class="text-xs font-semibold text-eth-red uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">
    View →
  </span>
</a>

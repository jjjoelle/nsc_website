---
interface Props {
  slug: string;
  name: string;
  batch_start: number;
  batch_end?: number;
  bio?: string;
  linkedin?: string;
}

const { slug, name, batch_start, batch_end, bio, linkedin } = Astro.props;
const status = batch_end ? `${batch_start}–${batch_end}` : `${batch_start}–present`;
---

<a href={`/students/${slug}`} class="block border-2 border-border hover:border-border-bold transition-colors p-6 group">
  <div class="flex items-baseline justify-between mb-2">
    <h3 class="text-lg font-bold group-hover:text-eth-red transition-colors">{name}</h3>
    <span class="text-xs font-mono font-semibold text-ink-light tracking-wide">{status}</span>
  </div>
  {bio && <p class="text-sm text-ink-light line-clamp-2">{bio}</p>}
  <div class="mt-3 flex gap-3 items-center">
    {linkedin && (
      <span class="text-xs font-medium text-ink-light">LinkedIn</span>
    )}
    <span class="ml-auto text-xs font-semibold text-eth-red uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">
      View Profile →
    </span>
  </div>
</a>
